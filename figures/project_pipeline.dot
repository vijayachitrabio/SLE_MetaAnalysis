digraph SLE_Publication_Pipeline {
    // --- Global Aesthetics (Optimized for Publication) ---
    graph [rankdir=TB, nodesep=0.5, ranksep=0.7, fontname="Arial", 
           labeljust="c", labelloc="t", compound=true, penwidth=0.8];
    node [fontname="Arial", fontsize=11, style="filled,rounded", shape=box, margin="0.2,0.1", penwidth=1.2];
    edge [color="#444444", arrowhead=vee, arrowsize=1.0, penwidth=1.0];

    // --- Stage 1: Discovery Phase (Northern Europe) ---
    subgraph cluster_1 {
        label = "Stage 1: Discovery Phase (Northern/North-Eastern)";
        labeljust="c"; labelloc="t"; fontname="Arial Bold"; fontsize=14;
        color="#88CCEE"; style="rounded,filled"; fillcolor="#F2F9FF"; margin=25;

        discovery [label="Discovery Meta-Analysis (IVW Fixed-Effects)\nBentham (N=4,036 cases) + FinnGen R12 (N=1,306 cases)\nTotal Cases: ~5,342", fillcolor="#FFFFFF", color="#88CCEE", fontname="Arial Bold"];
    }

    // --- Stage 2: Independent Validation (Southern Europe) ---
    subgraph cluster_2 {
        label = "Stage 2: Independent Geographic Validation";
        labeljust="c"; labelloc="t"; fontname="Arial Bold"; fontsize=14;
        color="#AA4499"; style="rounded,filled"; fillcolor="#FAF4FA"; margin=25;

        replication [label="Southern European Replication (Spanish Only)\nCases: 907 | Controls: 1,558\nIndependent Validation Target", fillcolor="#FFFFFF", color="#AA4499", fontname="Arial Bold"];
    }

    // --- Stage 3: Functional & Clinical Translation ---
    subgraph cluster_3 {
        label = "Stage 3: Biology & Clinical Translation";
        labeljust="c"; labelloc="t"; fontname="Arial Bold"; fontsize=14;
        color="#CC6677"; style="rounded,filled"; fillcolor="#FFF4F4"; margin=25;

        enrich  [label="Pathway Enrichment (fgsea / gProfiler)\nNES-based Biological Theme Mapping", fillcolor="#FFFFFF", color="#CC6677"];
        eqtl    [label="Functional Evidence (GTEx v8/v10)\nImmune-tissue cis-eQTL mapping",    fillcolor="#FFFFFF", color="#CC6677"];
        ppi     [label="Protein Interaction Network (STRING-DB)\nGene Core Connectivity Analysis", fillcolor="#FFFFFF", color="#CC6677"];
        drug    [label="Therapeutic Prioritization\nDrug-Target Mapping",       fillcolor="#FFFFFF", color="#882255", fontname="Arial Bold"];
    }

    // --- Flow Logic ---
    discovery -> replication [label=" 57 Independent\n Signals Identified"];
    replication -> enrich [label=" 26 Replicated Loci"];
    replication -> eqtl;
    replication -> ppi;

    enrich  -> drug;
    eqtl    -> drug;
    ppi     -> drug;
}
